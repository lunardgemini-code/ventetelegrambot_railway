{
  "id": "./",
  "name": "VenteBot Admin Console",
  "short_name": "VenteBot",
  "description": "Operational administration dashboard for VenteBot.",
  "lang": "en",
  "dir": "auto",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "orientation": "any",
  "background_color": "#151820",
  "theme_color": "#151820",
  "categories": [
    "business",
    "productivity"
  ],
  "icons": [
    {
      "src": "icons/ventebot-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/ventebot-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/ventebot-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
