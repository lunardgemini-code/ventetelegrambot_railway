BOT_TOKEN=your_telegram_bot_token
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_PAY_ID=your_binance_pay_id
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_ENABLED=false
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_FIXED_RATE=false
NOWPAYMENTS_FEE_PAID_BY_USER=false
NOWPAYMENTS_RECONCILE_SECONDS=180
NOWPAYMENTS_POLL_BATCH=5
PAYMENT_TIMEOUT_SECONDS=300
# Optional on Railway: automatically derived from RAILWAY_PUBLIC_DOMAIN.
# NOWPAYMENTS_CALLBACK_URL=https://your-app.up.railway.app/webhooks/nowpayments
CANBOSO_API_KEY=your_telegram_buyer_api_key
CANBOSO_API_BASE_URL=https://canboso.com
CANBOSO_API_AUTH_HEADER=X-API-Key
NANLUX_API_KEY=your_dealer_api_key
NANLUX_API_BASE_URL=https://api.mmonanlux.site
NANLUX_API_AUTH_HEADER=X-API-KEY
# Source-currency conversion used for MMO NanLux prices and wallet limits.
NANLUX_VND_PER_USD=25000

# Optional virtual sports prediction game (football-data.org)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
GAME_DAILY_CLAIM=300
GAME_DEFAULT_MIN_STAKE=25
GAME_DEFAULT_MAX_STAKE=500
GAME_DEFAULT_FEE_BPS=500
GAME_SYNC_WORKER_SECONDS=120
SUPPLIER_BALANCE_CACHE_SECONDS=120
ADMIN_IDS=123456789
ADMIN_API_KEY=your_secure_admin_api_key
WEBHOOK_SECRET=your_telegram_webhook_secret
CORS_ORIGINS=https://your-app.up.railway.app
# Allow dashboard/index.html opened directly with file:// (Origin: null).
ALLOW_FILE_DASHBOARD=true
# Allow dashboards deployed on any HTTPS *.netlify.app subdomain.
ALLOW_NETLIFY_DASHBOARD=true
WEBHOOK_QUEUE_MAX=1000
WEBHOOK_WORKERS=8
WEBHOOK_USER_QUEUE_MAX=12
WEBHOOK_AUTOSCALE_ENABLED=true
# First production stage: record decisions without changing live workers.
WEBHOOK_AUTOSCALE_OBSERVE_ONLY=true
WEBHOOK_WORKERS_MIN=8
WEBHOOK_WORKERS_MAX=20
WEBHOOK_WORKERS_INITIAL=8
WEBHOOK_AUTOSCALE_CALM_SECONDS=300
WEBHOOK_AUTOSCALE_PRESSURE_SAMPLES=2
WEBHOOK_AUTOSCALE_UP_COOLDOWN_SECONDS=15
WEBHOOK_AUTOSCALE_RECOVERY_SECONDS=120
WEBHOOK_AUTOSCALE_MEMORY_LIMIT_MB=450
SUBSCRIPTION_CACHE_SECONDS=3600
STOCK_COUNTS_CACHE_SECONDS=10
RESELLER_CATALOG_CACHE_SECONDS=15
CRITICAL_DB_CONCURRENCY=6
BINANCE_CONCURRENCY=4
NOWPAYMENTS_CONCURRENCY=4
SUPPLIER_CONCURRENCY=3
SUPPLIER_STOCK_BALANCE_TIMEOUT_SECONDS=2
SUPPLIER_CATALOG_SYNC_SECONDS=90
SUPPLIER_CATALOG_FULL_SYNC_SECONDS=1800
SPORTS_API_CONCURRENCY=2
BLOCKCHAIN_API_CONCURRENCY=3
EXTERNAL_QUEUE_TIMEOUT_SECONDS=5
EXTERNAL_CIRCUIT_FAILURES=5
EXTERNAL_CIRCUIT_COOLDOWN_SECONDS=15
TURSO_POOL_MAX_IDLE_SECONDS=5
TURSO_POOL_MAX_LIFETIME_SECONDS=30
# Bound native Turso calls and serialize SQLite write transactions per process.
TURSO_OPERATION_TIMEOUT_SECONDS=15
TURSO_CLOSE_TIMEOUT_SECONDS=3
TURSO_WRITE_LOCK_TIMEOUT_SECONDS=15
# Limit simultaneous native connection handshakes during traffic spikes/restarts.
TURSO_CONNECT_CONCURRENCY=4
# Independent process that restarts a frozen event loop on Railway.
PROCESS_WATCHDOG_ENABLED=true
PROCESS_WATCHDOG_STARTUP_GRACE_SECONDS=20
PROCESS_WATCHDOG_INTERVAL_SECONDS=10
PROCESS_WATCHDOG_TIMEOUT_SECONDS=3
PROCESS_WATCHDOG_FAILURE_THRESHOLD=5
PROCESS_WATCHDOG_DIAGNOSTIC_DELAY_SECONDS=2
# PID 1 supervisor: restart a bot killed by the watchdog, then let Railway
# replace the container if too many restarts happen in one window.
PROCESS_SUPERVISOR_RESTART_DELAY_SECONDS=2
PROCESS_SUPERVISOR_MAX_RESTARTS=5
PROCESS_SUPERVISOR_RESTART_WINDOW_SECONDS=600
# Local API-only testing only; keep true on Railway.
HEALTHCHECK_REQUIRE_BOT=true
